# Drifting Infinity — Backend Configuration
# Copy this file to .env and fill in values for your environment.

# Database (SQLite default; change for PostgreSQL in production)
# DATABASE_URL=sqlite+aiosqlite:///data/drifting_infinity.db

# Open5e API (used for monster/spell/magic item ingestion on first run)
# OPEN5E_BASE_URL=https://api.open5e.com/v1

# LLM Integration (Phase 4) — optional
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_ENABLED=false

# CORS — comma-separated list of allowed frontend origins
# CORS_ORIGINS=["http://localhost:5173"]

# Debug mode (disable in production)
# DEBUG=true
